// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgres://postgres.mabfjyjbggqdwqtjdwip:xsGPNFAYUJJEV9Xp@aws-0-us-east-1.pooler.supabase.com:5432/postgres?connection_limit=50&pool_timeout=200"
}

model Habit {
  name          String          @id
  createdAt     DateTime        @default(now())
  updatedAt     DateTime?       @updatedAt
  isPro         Boolean         @default(false)
  minutes       Int             @default(5)
  wideImage     String?
  tallImage     String?
  points        Int             @default(0)
  followersQty  Int             @default(0)
  subscriptions Subscriptions[]
  title         String
  subtitle      String
}

model User {
  id            String          @unique @default(uuid())
  name          String
  email         String          @id
  isPro         Boolean         @default(false)
  points        Int             @default(0)
  img           String?
  subscriptions Subscriptions[]
  badges        BadgeOfUser[]
}

model Subscriptions {
  user      User   @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  userEmail String
  habit     Habit  @relation(fields: [habitName], references: [name])
  habitName String

  // middle fields
  isFollowing Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  completedAt DateTime?
  streak      Int       @default(0)

  @@id([userEmail, habitName])
}

model Badge {
  title  String        @unique
  badges BadgeOfUser[]
}

model BadgeOfUser {
  obtainedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  User       User     @relation(fields: [userEmail], references: [email])
  userEmail  String
  Badge      Badge    @relation(fields: [badgeTitle], references: [title])
  badgeTitle String

  @@id([userEmail, badgeTitle])
}
